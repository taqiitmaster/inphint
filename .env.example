# ────────────────────────────────────────────────────────────
#  Inphint — environment variables
#  Copy this file to ".env" and fill in the values.
# ────────────────────────────────────────────────────────────

# ── Neon database (required) ────────────────────────────────
# 1. Create a free project at https://neon.tech
# 2. In the dashboard, open "Connection Details" and copy the
#    POOLED connection string (host contains "-pooler").
# 3. Paste it below. Keep ?sslmode=require on the end.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Admin panel login (required to use /admin) ──────────────
ADMIN_USERNAME="admin"
# Use ONE of the two below. ADMIN_PASSWORD_HASH (bcrypt) is safer for production.
ADMIN_PASSWORD="change-this-password"
# ADMIN_PASSWORD_HASH="$2a$10$....."   # bcrypt hash; overrides ADMIN_PASSWORD if set

# Secret used to sign admin login tokens. Use a long random string.
JWT_SECRET="please-change-this-to-a-long-random-string"

# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── Inphox chatbot (optional but recommended) ───────────────
# Get a free key at https://aistudio.google.com/apikey
# Without this, Inphox still works using its built-in keyword replies.
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash"   # optional override, this is the default

# ── Email notifications (optional) ──────────────────────────
# If these are set, every new contact-form enquiry is emailed to NOTIFY_TO.
# Leave blank to skip email — enquiries are always saved to the database.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="app-password"
# SMTP_FROM="Inphint <your@gmail.com>"
# NOTIFY_TO="inphint@gmail.com"
